ntryProcessor":{"showCharactersCount":false,"numberOfLines":5,"placeholder":"","inputFieldId":"ObjectField_comment"}}','mbrh',0,'INPUTS-textarea',3,'2026-04-02 15:53:24.447000',NULL)
