INSERT INTO DDMTEMPLATEVERSION VALUES(0,0,68500,20119,16796623585306,20095,NULL,'2024-08-07 01:06:31.675000',31667,0,31674,'1.2','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL" default-locale="en_US"><Name language-id="en_US">Card Layout</Name><Name language-id="ar_SA">\u0645\u062e\u0637\u0637 \u0627\u0644\u0628\u0637\u0627\u0642\u0629</Name><Name language-id="ca_ES">Disposici\u00f3 de la targeta</Name><Name language-id="zh_CN">\u5361\u7247\u5e03\u5c40</Name><Name language-id="nl_NL">Kaartlay-out</Name><Name language-id="fi_FI">Kortin Asettelu</Name><Name language-id="fr_FR">Disposition de la carte</Name><Name language-id="de_DE">Kartenlayout</Name><Name language-id="hu_HU">K\u00e1rtyaelrendez\u00e9s</Name><Name language-id="ja_JP">\u30ab\u30fc\u30c9\u30ec\u30a4\u30a2\u30a6\u30c8</Name><Name language-id="pt_BR">Layout do cart\u00e3o</Name><Name language-id="es_ES">Dise\u00f1o de tarjeta</Name><Name language-id="sv_SE">Kortlayout</Name></root>','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL" default-locale="en_US"><Description language-id="en_US">Display results with a grid of cards.</Description><Description language-id="ar_SA">\u0639\u0631\u0636 \u0627\u0644\u0646\u062a\u0627\u0626\u062c \u0645\u0646 \u062e\u0644\u0627\u0644 \u0634\u0628\u0643\u0629 \u0645\u0646 \u0627\u0644\u0628\u0637\u0627\u0642\u0627\u062a.</Description><Description language-id="ca_ES">Mostra els resultats com una s\u00e8rie de cartes.</Description><Description language-id="zh_CN">\u663e\u793a\u7ed3\u679c\u4e0e\u5361\u7247\u7f51\u683c\u3002</Description><Description language-id="nl_NL">Resultaten weergeven als een kaartenrooster.</Description><Description language-id="fi_FI">N\u00e4yt\u00e4 tulokset korttien ruudukkona.</Description><Description language-id="fr_FR">Afficher les r\u00e9sultats sous la forme de grille de cartes.</Description><Description language-id="de_DE">Ergebnisse als Kartengitter anzeigen.</Description><Description language-id="hu_HU">Az eredm\u00e9nyeket jelen\u00edtse meg k\u00e1rtyar\u00e1csk\u00e9nt.</Description><Description language-id="ja_JP">\u7d50\u679c\u3092\u30b0\u30ea\u30c3\u30c9\u72b6\u306b\u914d\u7f6e\u3057\u305f\u30ab\u30fc\u30c9\u3067\u8868\u793a\u3057\u307e\u3059\u3002</Description><Description language-id="pt_BR">Exibir resultados com uma s\u00e9rie de cart\u00f5es.</Description><Description language-id="es_ES">Muestra resultados con una cuadr\u00edcula de tarjetas.</Description><Description language-id="sv_SE">Visa resultat som ett rutn\u00e4t med kort.</Description></root>','ftl','<div class="c-mb-4 c-mt-4 search-total-label">\u000a\u0009<#if searchContainer.getTotal() == 1>\u000a\u0009\u0009${languageUtil.format(locale, "x-result-for-x", [searchContainer.getTotal(), "<strong>" + htmlUtil.escape(searchResultsPortletDisplayContext.getKeywords()) + "</strong>"], false)}\u000a\u0009<#else>\u000a\u0009\u0009${languageUtil.format(locale, "x-results-for-x", [searchContainer.getTotal(), "<strong>" + htmlUtil.escape(searchResultsPortletDisplayContext.getKeywords()) + "</strong>"], false)}\u000a\u0009</#if>\u000a</div>\u000a\u000a<div class="display-card">\u000a\u0009<ul class="card-page">\u000a\u0009\u0009<#if entries?has_content>\u000a\u0009\u0009\u0009<#list entries as entry>\u000a\u0009\u0009\u0009\u0009<li class="card-page-item card-page-item-asset">\u000a\u0009\u0009\u0009\u0009\u0009<div class="card card-type-asset file-card">\u000a\u0009\u0009\u0009\u0009\u0009\u0009<div class="aspect-ratio card-item-first">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#if entry.isThumbnailVisible()>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<img alt="${htmlUtil.escape(entry.getTitle())}" class="aspect-ratio-item aspect-ratio-item-center-middle aspect-ratio-item-vertical-fluid" src="${entry.getThumbnailURLString()}" />\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#elseif entry.isUserPortraitVisible() && stringUtil.equals(entry.getClassName(), userClassName)>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<div class="user-card">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<div class="aspect-ratio-item aspect-ratio-item-center-middle aspect-ratio-item-vertical-fluid card-type-asset-icon">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="sticker sticker-secondary sticker-user-icon">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="sticker-overlay">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<img alt="${htmlUtil.escape(entry.getTitle())}" class="img-fluid" src="${entry.getUserPortraitURLString()}" />\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</div>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</div>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<#else>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<div class="aspect-ratio-item aspect-ratio-item-center-middle aspect-ratio-item-vertical-fluid card-type-asset-icon">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<@clay.icon symbol="${(entry.isIconVisible())?then(entry.getIconId(),''web-content'')}" />\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</div>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009</#if>\u000a\u0009\u0009\u0009\u0009\u0009\u0009</div>\u000a\u000a\u0009\u0009\u0009\u0009\u0009\u0009<div class="card-body">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<div class="card-row">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<div class="autofit-col autofit-col-expand">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<section class="autofit-section">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u