INSERT INTO DDMTEMPLATE VALUES(4,0,'4698c298-94ce-3ee4-44d7-7dd78460259c',31671,20119,16796623585306,20095,NULL,20095,NULL,'2024-05-13 14:37:49.919000','2026-04-02 16:11:29.600000',31667,0,31505,'SEARCH-RESULTS-LIST-FTL','1.4','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL" default-locale="en_US"><Name language-id="en_US">List Layout</Name><Name language-id="ar_SA">\u0645\u062e\u0637\u0637 \u0627\u0644\u0642\u0627\u0626\u0645\u0629</Name><Name language-id="ca_ES">Disposici\u00f3 de la llista</Name><Name language-id="zh_CN">\u5217\u8868\u5e03\u5c40</Name><Name language-id="nl_NL">Lijstlay-out</Name><Name language-id="fi_FI">Luetteloasettelu</Name><Name language-id="fr_FR">Disposition en liste</Name><Name language-id="de_DE">Listenlayout</Name><Name language-id="hu_HU">Lista elrendez\u00e9s</Name><Name language-id="ja_JP">\u30ea\u30b9\u30c8\u30ec\u30a4\u30a2\u30a6\u30c8</Name><Name language-id="pt_BR">Layout da lista</Name><Name language-id="es_ES">Dise\u00f1o de lista</Name><Name language-id="sv_SE">Listlayout</Name></root>','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL" default-locale="en_US"><Description language-id="en_US">Display results with their title, creator''s user name, asset type, and creation date.</Description><Description language-id="ar_SA">\u0639\u0631\u0636 \u0627\u0644\u0646\u062a\u0627\u0626\u062c \u0645\u0646 \u062e\u0644\u0627\u0644 \u0639\u0646\u0627\u0648\u064a\u0646\u0647\u0627\u060c \u0648\u0627\u0633\u0645 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645 \u0627\u0644\u0645\u0646\u0634\u0626 \u0648\u0646\u0648\u0639 \u0627\u0644\u0623\u0635\u0644 \u0648\u062a\u0627\u0631\u064a\u062e \u0627\u0644\u0625\u0646\u0634\u0627\u0621.</Description><Description language-id="ca_ES">Mostra els resultats amb el t\u00edtol, el nom d''usuari del creador, el tipus de contingut i la data de creaci\u00f3.</Description><Description language-id="zh_CN">\u663e\u793a\u7ed3\u679c\u53ca\u5176\u6807\u9898\u3001\u521b\u5efa\u8005\u7528\u6237\u540d\u3001\u8d44\u6e90\u7c7b\u578b\u548c\u521b\u5efa\u65e5\u671f\u3002</Description><Description language-id="nl_NL">Resultaten weergeven met hun titel, de gebruikersnaam van de maker, het assettype en de aanmaakdatum.</Description><Description language-id="fi_FI">N\u00e4yt\u00e4 tulokset otsikoineen, luojan k\u00e4ytt\u00e4j\u00e4nimineen, sis\u00e4lt\u00f6tyyppeineen ja luontip\u00e4ivineen.</Description><Description language-id="fr_FR">Afficher les r\u00e9sultats avec leur intitul\u00e9, le nom d''utilisateur du cr\u00e9ateur, le type d''actif et la date de cr\u00e9ation.</Description><Description language-id="de_DE">Ergebnisse mit deren Titel, Benutzername des Erstellers, Assettyp und Erstellungsdatum anzeigen.</Description><Description language-id="hu_HU">A tal\u00e1latokat jelen\u00edtse meg c\u00edmmel, a k\u00e9sz\u00edt\u0151 felhaszn\u00e1l\u00f3nev\u00e9vel, tartalomt\u00edpussal \u00e9s le\u00edr\u00e1ssal.</Description><Description language-id="ja_JP">\u7d50\u679c\u3068\u305d\u306e\u30bf\u30a4\u30c8\u30eb\u3001\u4f5c\u6210\u8005\u306e\u30e6\u30fc\u30b6\u30fc\u540d\u3001\u30a2\u30bb\u30c3\u30c8\u30bf\u30a4\u30d7\u3001\u4f5c\u6210\u65e5\u3092\u8868\u793a\u3057\u307e\u3059\u3002</Description><Description language-id="pt_BR">Exibir resultados com seus t\u00edtulos, nome de usu\u00e1rio do criador, tipo de conte\u00fado e data de cria\u00e7\u00e3o.</Description><Description language-id="es_ES">Muestra resultados con el t\u00edtulo, el nombre de usuario del autor, el tipo de activo y la fecha de creaci\u00f3n.</Description><Description language-id="sv_SE">Visa resultat med titel, skaparens anv\u00e4ndarnamn, tillg\u00e5ngstyp och skapandedatum.</Description></root>','display',NULL,'ftl','<div class="c-mb-4 c-mt-4 search-total-label">\u000a\u0009<#if searchContainer.getTotal() == 1>\u000a\u0009\u0009${languageUtil.format(locale, "x-result-for-x", [searchContainer.getTotal(), "<strong>" + htmlUtil.escape(searchResultsPortletDisplayContext.getKeywords()) + "</strong>"], false)}\u000a\u0009<#else>\u000a\u0009\u0009${languageUtil.format(locale, "x-results-for-x", [searchContainer.getTotal(), "<strong>" + htmlUtil.escape(searchResultsPortletDisplayContext.getKeywords()) + "</strong>"], false)}\u000a\u0009</#if>\u000a</div>\u000a\u000a<div class="display-list">\u000a\u0009<ul class="list-group" id="search-results-display-list">\u000a\u0009\u0009<#if entries?has_content>\u000a\u0009\u0009\u0009<#list entries as entry>\u000a\u0009\u0009\u0009\u0009<li class="list-group-item list-group-item-flex">\u000a\u0009\u0009\u0009\u0009\u0009<div class="autofit-col">\u000a\u0009\u0009\u0009\u0009\u0009\u0009<#if entry.isThumbnailVisible()>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="sticker">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="sticker-overlay">\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009<img\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009alt="${htmlUtil.escape(entry.getTitle()) + '' '' + languageUtil.get(locale, ''thumbnail'')}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009class="sticker-img"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009src="${entry.getThumbnailURLString()}"\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009/>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009\u0009\u0009\u0009<#elseif entry.isUserPortraitVisible() && stringUtil.equals(entry.getClassName(), userClassName)>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<@liferay_ui["user-portrait"] userId=entry.getAssetEntryUserId() />\u000a\u0009\u0009\u0009\u0009\u0009\u0009<#elseif entry.isIconVisible()>\u000a\u0009\u0009\u0009\u0009\u0009\u0009\u0009<span class="sticker sticker-rounded sticker-secondary sticker-static">\u