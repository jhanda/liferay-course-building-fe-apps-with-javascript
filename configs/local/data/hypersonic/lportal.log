INSERT INTO FRAGMENTENTRYLINK VALUES(94,0,'2839610f-de48-5894-9b73-9d946897b049','2839610f-de48-5894-9b73-9d946897b049',34190,32106,16796623585306,20122,'Clarity Admin','2024-05-20 20:34:23.000000','2026-04-02 15:53:29.765000','','','',63423,20031,26,26,'.component-html img {\u000a\u0009max-width: 100%;\u000a}','<div class="component-html" data-lfr-editable-id="element-html" data-lfr-editable-type="html">\u000a\u0009<h1>HTML Example</h1>\u000a\u000a\u0009<p class="mb-0">\u000a\u0009\u0009A paragraph is a <strong>self-contained</strong> unit of a discourse in\u000a\u0009\u0009writing dealing with a particular point or <em>idea</em>. Paragraphs are\u000a\u0009\u0009usually an expected part of formal writing, used to organize longer\u000a\u0009\u0009prose.\u000a\u0009</p>\u000a</div>','','','0','{"com.liferay.fragment.entry.processor.editable.EditableFragmentEntryProcessor":{"element-html":{"defaultValue":"\n\t<h1>HTML Example<\/h1>\n\n\t<p class=\"mb-0\">\n\t\tA paragraph is a <strong>self-contained<\/strong> unit of a discourse in\n\t\twriting dealing with a particular point or <em>idea<\/em>. Paragraphs are\n\t\tusually an expected part of formal writing, used to organize longer\n\t\tprose.\n\t<\/p>\n","en_US":"\n\t<h1>Making a Positive<br>Impact, Sustainably<\/h1>\n\n\t<p class=\"mb-2 mt-3 text-small\">\n    At Clarity, our commitment to making a difference goes beyond stylish eyewear. \n    Through initiatives like empowering underserved communities with access to quality \n    eyewear, we bridge vision gaps and contribute to socail well-being. \n    Simultaneously, our dedication to sustainability is reflected in our eco-friendly\t\n    practices, from responsible material sourcing to the use of recyclable packaging.\n    Every purchase you make with us not only enhances your style but also supports our\n    collective journey toward a brighter, more includsive, and susainable future. \n<\/p>\n","config":{}}}}','hmyb',0,'BASIC_COMPONENT-html',1,'2026-04-02 15:53:29.765000',NULL)
COMMIT
