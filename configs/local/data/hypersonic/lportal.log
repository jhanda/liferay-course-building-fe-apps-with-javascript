INSERT INTO DDMTEMPLATEVERSION VALUES(0,0,68501,20119,16796623585306,20095,NULL,'2024-05-13 14:37:50.334000',31677,0,31678,'1.1','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL" default-locale="en_US"><Name language-id="en_US">Compact Layout</Name><Name language-id="ar_SA">\u0645\u062e\u0637\u0637 \u0645\u0636\u063a\u0648\u0637</Name><Name language-id="ca_ES">Disposici\u00f3 compacta</Name><Name language-id="zh_CN">\u7d27\u51d1\u5e03\u5c40</Name><Name language-id="nl_NL">Compacte lay-out</Name><Name language-id="fi_FI">Tiivis Asettelu</Name><Name language-id="fr_FR">Disposition compacte</Name><Name language-id="de_DE">Kompaktes Layout</Name><Name language-id="hu_HU">Kompakt elrendez\u00e9s</Name><Name language-id="ja_JP">\u30b3\u30f3\u30d1\u30af\u30c8\u30ec\u30a4\u30a2\u30a6\u30c8</Name><Name language-id="pt_BR">Layout compacto</Name><Name language-id="es_ES">Dise\u00f1o compacto</Name><Name language-id="sv_SE">Kompakt layout</Name></root>','<?xml version="1.0" ?><root available-locales="en_US,sv_SE,pt_BR,ja_JP,fr_FR,hu_HU,de_DE,ca_ES,ar_SA,fi_FI,zh_CN,es_ES,nl_NL" default-locale="en_US"><Description language-id="en_US">Display terms as a list of links.</Description><Description language-id="ar_SA">\u0639\u0631\u0636 \u0627\u0644\u0645\u0635\u0637\u0644\u062d\u0627\u062a \u0643\u0642\u0627\u0626\u0645\u0629 \u0645\u0646 \u0627\u0644\u0631\u0648\u0627\u0628\u0637.</Description><Description language-id="ca_ES">Mostra els termes com una llista d''enlla\u00e7os.</Description><Description language-id="zh_CN">\u5c06\u641c\u7d22\u8bcd\u663e\u793a\u4e3a\u94fe\u63a5\u5217\u8868\u3002</Description><Description language-id="nl_NL">Termen weergeven als een lijst met links.</Description><Description language-id="fi_FI">N\u00e4yt\u00e4 termit linkkien luettelona.</Description><Description language-id="fr_FR">Afficher les termes sous la forme de liste de liens.</Description><Description language-id="de_DE">Begriffe als Linkliste anzeigen.</Description><Description language-id="hu_HU">Jelen\u00edtse meg a kifejez\u00e9seket hivatkoz\u00e1sok list\u00e1jak\u00e9nt.</Description><Description language-id="ja_JP">\u7528\u8a9e\u3092\u30ea\u30f3\u30af\u30ea\u30b9\u30c8\u3068\u3057\u3066\u8868\u793a\u3057\u307e\u3059\u3002</Description><Description language-id="pt_BR">Exibir termos como uma lista de links.</Description><Description language-id="es_ES">Muestra t\u00e9rminos como una lista de enlaces.</Description><Description language-id="sv_SE">Visa villkoren som en lista med l\u00e4nkar.</Description></root>','ftl','<@liferay_ui["panel-container"]\u000a\u0009extended=true\u000a\u0009id="${namespace + ''facetScopePanelContainer''}"\u000a\u0009markupView="lexicon"\u000a\u0009persistState=true\u000a>\u000a\u0009<@liferay_ui.panel\u000a\u0009\u0009collapsible=true\u000a\u0009\u0009cssClass="search-facet"\u000a\u0009\u0009id="${namespace + ''facetScopePanel''}"\u000a\u0009\u0009markupView="lexicon"\u000a\u0009\u0009persistState=true\u000a\u0009\u0009title="site"\u000a\u0009>\u000a\u0009\u0009<#if !scopeSearchFacetDisplayContext.isNothingSelected()>\u000a\u0009\u0009\u0009<@clay.button\u000a\u0009\u0009\u0009\u0009cssClass="btn-unstyled c-mb-4 facet-clear-btn"\u000a\u0009\u0009\u0009\u0009displayType="link"\u000a\u0009\u0009\u0009\u0009id="${namespace + ''facetScopeClear''}"\u000a\u0009\u0009\u0009\u0009onClick="Liferay.Search.FacetUtil.clearSelections(event);"\u000a\u0009\u0009\u0009>\u000a\u0009\u0009\u0009\u0009<strong>${languageUtil.get(locale, "clear")}</strong>\u000a\u000a\u0009\u0009\u0009\u0009<span class="sr-only">\u000a\u0009\u0009\u0009\u0009\u0009${languageUtil.format(locale, ''x-filter'', ''site-facet-portlet-instance-configuration-name'')}\u000a\u0009\u0009\u0009\u0009</span>\u000a\u0009\u0009\u0009</@clay.button>\u000a\u0009\u0009</#if>\u000a\u000a\u0009\u0009<ul class="list-unstyled">\u000a\u0009\u0009\u0009<#if entries?has_content>\u000a\u0009\u0009\u0009\u0009