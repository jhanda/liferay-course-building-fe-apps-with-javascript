INSERT INTO FRAGMENTENTRYLINK VALUES(101,0,'d52b1975-7437-0b1c-59c8-741f05d3052c','d52b1975-7437-0b1c-59c8-741f05d3052c',34356,32106,16796623585306,20122,'Clarity Admin','2024-05-20 20:50:02.000000','2026-04-29 19:53:40.385000','5a8336b8-b142-bec1-9a96-e77b6b82d555','','',32486,20031,35,35,'.component-paragraph img {\u000a\u0009max-width: 100%;\u000a}','<div class="clearfix component-paragraph text-break" data-lfr-editable-id="element-text" data-lfr-editable-type="rich-text">\u000a\u0009<p>\u000a\u0009\u0009A paragraph is a self-contained unit of a discourse in writing dealing with\u000a\u0009\u0009a particular point or idea. Paragraphs are usually an expected part of\u000a\u0009\u0009formal writing, used to organize longer prose.\u000a\u0009</p>\u000a</div>','','','0','{"com.liferay.fragment.entry.processor.editable.EditableFragmentEntryProcessor":{"element-text":{"defaultValue":"\n\t<p>\n\t\tA paragraph is a self-contained unit of a discourse in writing dealing with\n\t\ta particular point or idea. Paragraphs are usually an expected part of\n\t\tformal writing, used to organize longer prose.\n\t<\/p>\n\n\n","en_US":"All-round development, provide customers with more choices","config":{"mapperType":"link"}}}}','rayy',1,'BASIC_COMPONENT-paragraph',1,'2026-04-29 16:55:40.969000',NULL)
