INSERT INTO FRAGMENTENTRYLINK VALUES(58,0,'cc42d4ec-a5c4-fd6b-d109-9eb23baa6740','cc42d4ec-a5c4-fd6b-d109-9eb23baa6740',45432,32106,16796623585306,20122,'Clarity Admin','2024-08-15 18:27:57.000000','2026-04-29 19:53:40.386000','28849b37-6212-dd3a-949c-ea5fa0c91dfb','','',32486,20031,35,35,'.component-html img {\u000a\u0009max-width: 100%;\u000a}','<div class="component-html" data-lfr-editable-id="element-html" data-lfr-editable-type="html">\u000a\u0009<h1>HTML Example</h1>\u000a\u000a\u0009<p class="mb-0">\u000a\u0009\u0009A paragraph is a <strong>self-contained</strong> unit of a discourse in\u000a\u0009\u0009writing dealing with a particular point or <em>idea</em>. Paragraphs are\u000a\u0009\u0009usually an expected part of formal writing, used to organize longer\u000a\u0009\u0009prose.\u000a\u0009</p>\u000a</div>','','','0','{"com.liferay.fragment.entry.processor.editable.EditableFragmentEntryProcessor":{"element-html":{"classPK":"45263","itemType":"Web Content Article","defaultValue":"\n\t<h1>HTML Example<\/h1>\n\n\t<p class=\"mb-0\">\n\t\tA paragraph is a <strong>self-contained<\/strong> unit of a discourse in\n\t\twriting dealing with a particular point or <em>idea<\/em>. Paragraphs are\n\t\tusually an expected part of formal writing, used to organize longer\n\t\tprose.\n\t<\/p>\n","className":"com.liferay.journal.model.JournalArticle","itemSubtype":"Basic Web Content","classNameId":"29208","title":"Our Story","config":{},"classTypeId":"30514","fieldId":"DDMStructure_content"}}}','jyxt',0,'BASIC_COMPONENT-html',1,'2026-04-29 16:55:40.968000',NULL)
